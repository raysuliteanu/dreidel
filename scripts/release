#!/usr/bin/env bash
# Release script for dreidel.
#
# Usage: scripts/release [-n|--dry-run] [patch|minor|major]
#
# Runs cargo-release to bump the version, regenerate CHANGELOG.md, commit, and
# tag, then syncs jj and pushes the bookmark and tag to origin.
#
# Dry-run mode (-n / --dry-run):
#   - cargo release runs without --execute (its own dry-run)
#   - jj/git push commands are echoed with the real resolved values but not run

set -euo pipefail

DRY_RUN=false
LEVEL=patch

for arg in "$@"; do
    case "$arg" in
        -n | --dry-run) DRY_RUN=true ;;
        patch | minor | major) LEVEL="$arg" ;;
        *)
            printf 'error: unknown argument "%s"\n' "$arg" >&2
            printf 'usage: scripts/release [-n|--dry-run] [patch|minor|major]\n' >&2
            exit 1
            ;;
    esac
done

if ! command -v cargo-release >/dev/null 2>&1; then
    printf 'error: cargo-release not found; run: cargo install cargo-release --locked\n' >&2
    exit 1
fi

if ! command -v git-cliff >/dev/null 2>&1; then
    printf 'error: git-cliff not found; run: brew install git-cliff\n' >&2
    exit 1
fi

if ! command -v jj >/dev/null 2>&1; then
    printf 'error: jj not installed or not on PATH\n' >&2
    exit 1
fi

if ! jj root >/dev/null 2>&1; then
    printf 'error: must be run inside a jj repository\n' >&2
    exit 1
fi

# Compute what the next version will be so dry-run echo lines show real values.
current_version=$(grep '^version = ' Cargo.toml | head -1 | cut -d'"' -f2)
IFS='.' read -r ver_major ver_minor ver_patch <<< "$current_version"
case "$LEVEL" in
    major) next_version="$((ver_major + 1)).0.0" ;;
    minor) next_version="${ver_major}.$((ver_minor + 1)).0" ;;
    patch) next_version="${ver_major}.${ver_minor}.$((ver_patch + 1))" ;;
esac
TAG="v${next_version}"

if "$DRY_RUN"; then
    printf '[dry run] %s -> %s\n\n' "$current_version" "$next_version"
    # cargo release has its own dry-run mode (omit --execute); let it run for real.
    # It always exits non-zero in dry-run ("aborting upload due to dry run"),
    # so suppress the exit code — the output is what matters here.
    cargo release "$LEVEL" || true
    printf '\n[dry run] would run:\n'
    printf '  jj git fetch\n'
    printf '  jj bookmark set main -r @-\n'
    printf '  jj git push --bookmark main\n'
    printf '  git push origin %s\n' "$TAG"
else
    # Bump version, regenerate CHANGELOG, commit, and create the git tag.
    cargo release "$LEVEL" --execute

    printf '\nPushing %s to origin...\n' "$TAG"

    # Sync jj's view of the git state, advance the main bookmark, and push.
    jj git fetch
    jj bookmark set main -r @-
    jj git push --bookmark main

    # Push the git tag that cargo-release created (jj doesn't manage git tags
    # directly; use git in the co-located repo).
    git push origin "$TAG"

    printf '\nReleased %s successfully.\n' "$TAG"
fi
